# Скопируйте этот файл в .env и заполните своими значениями.
# .env НЕ коммитьте в репозиторий — это секреты.

# === Telegram Bot ===
# Токен бота, выданный @BotFather
TELEGRAM_BOT_TOKEN=

# Username бота без @, например: volshebnyi_ogon_bot
TELEGRAM_BOT_USERNAME=

# Ваш chat_id (admin), куда приходят уведомления о заявках.
# Узнать можно через @userinfobot или /start у вашего бота, посмотрев в логах backend.
TELEGRAM_CHAT_ID=

# === Server ===
PORT=3000

# Разрешённый origin фронтенда (если фронт запущен отдельно).
# Для разработки с Live Server обычно: http://127.0.0.1:5500 или http://localhost:5500
ALLOWED_ORIGIN=*
